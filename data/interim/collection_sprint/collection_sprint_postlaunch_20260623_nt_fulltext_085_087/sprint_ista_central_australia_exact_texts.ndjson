{"acceptance_decision": "accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "accepted", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "Like the man who is on any particular occasion acting as a Kurdaitcha, the doctor himself must be an Ertwa Kurdaitcha who has qualified by passing through the ordeal by fire in which the toe is dislocated. Both men carry shields and spears, and also one or more Churinga, which are supposed as usual to impart to them strength, courage, accuracy of aim, and also to render them invisible to their enemies, and in addition they act as charms to prevent their wearers being wounded. Around his waist each one wears the Kirra-urkna, or girdle, made from the hair which has been cut from a warrior after his death and which is supposed to add.", "external_id": "sprint-ista-central-australi:ntca15:kurdaitcha:002", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "explicit_supernatural_or_anomalous_person_form_agent", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "spirit_person_narrative", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "B", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "0347d00cf1de4802122484ebbe965334c6c59645e12f738501b580903c8c8267", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "", "rights_access_status": "public_access_text_available", "secondary_role": "source_grounded_section_record", "source_label": "Kurdaitcha", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Kurdaitcha in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}

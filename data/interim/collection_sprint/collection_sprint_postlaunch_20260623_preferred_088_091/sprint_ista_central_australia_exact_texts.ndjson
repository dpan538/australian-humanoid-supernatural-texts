{"acceptance_decision": "not_accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "rejected", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "His death is attributed to Kurdaitcha or to some other form of magic influence, but no one will be able to trace the tracks of the Kurdaitcha.", "external_id": "sprint-ista-central-australi:ntca15:kurdaitcha:001", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "insufficient_person_form_evidence", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "reviewed_context", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "059b8d71758bfc8ee13558d50421707f080811257b4261acbb0f717597a7aaef", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "rejected", "rights_access_status": "public_access_text_available", "secondary_role": "context_only", "source_label": "Kurdaitcha", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Kurdaitcha in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}
{"acceptance_decision": "not_accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "lead_only", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "Sometimes instead of sucking the tongue, the Kurdaitcha catches a special kind of slender, smooth bodied lizard (Rhodona bipes) which frequents the roots of Mulga trees and inserts the head of the animal into the wound through which it is supposed to suck up all the blood.", "external_id": "sprint-ista-central-australi:ntca15:kurdaitcha:002", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "humanoid_adjacent_context", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "reviewed_context", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "b92d5f34c452f831316c8e24d12ea5ac2e8226af40618961b8aa0b293df8f5d6", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "context", "rights_access_status": "public_access_text_available", "secondary_role": "context_only", "source_label": "Kurdaitcha", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Kurdaitcha in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}
{"acceptance_decision": "accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "accepted", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "Whilst there is much of a mythical nature about the Kurdaitcha it is quite possible that there is a certain amount of truth underlying a good deal that is, of course, a matter of pure imagination. It is very possible that the shoes, if not actually used at the present day, have been used in past times for the purpose of aiding in secret killing and, to the present day, the fear of the Kurdaitcha man lurking around is always present with the native. We have met several Kurdaitcha men who claim to have killed their victim and many more men who are perfectly certain that they have seen Kurdaitcha One group of men will tell you that.", "external_id": "sprint-ista-central-australi:ntca15:kurdaitcha:003", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "explicit_supernatural_or_anomalous_person_form_agent", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "spirit_person_narrative", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "B", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "b24a6616687c4048ddbb43bfc825f446d8d305aaaeecf8074da75fcc45b757ec", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "", "rights_access_status": "public_access_text_available", "secondary_role": "source_grounded_section_record", "source_label": "Kurdaitcha", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Kurdaitcha in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}
{"acceptance_decision": "not_accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "rejected", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "Our impression with regard to the Kurdaitcha is that at the present day it is merely a matter of myth, though at the same time every native is firmly convinced that some other native does actually “go Kurdaitcha,” and is quite prepared, as a general rule, to allow others to think that he himself does; he will even go to the length of suffering the pain of having his toe dislocated in order to “prove” that he is a genuine Ertwa Kurdaitcha.", "external_id": "sprint-ista-central-australi:ntca15:kurdaitcha:004", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "insufficient_person_form_evidence", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "reviewed_context", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "99ee7dfdb829b4e2956c76a5ba53fb168d06875503c0f26c170ac76aaef2c341", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "rejected", "rights_access_status": "public_access_text_available", "secondary_role": "context_only", "source_label": "Kurdaitcha", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Kurdaitcha in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}
{"acceptance_decision": "accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "accepted", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "Under the treatment of an able medicine man, whose services were fortunately available, he recovered, after the extraction from his body of a number of pieces of a wooden Churinga.", "external_id": "sprint-ista-central-australi:ntca15:medicine-man:005", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "explicit_supernatural_or_anomalous_person_form_agent", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "B", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "3e136165872aa597f174353ef2c5bb148e2df279d57161d9897344761fcab82b", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "", "rights_access_status": "public_access_text_available", "secondary_role": "source_grounded_section_record", "source_label": "Medicine man", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Medicine man in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}
{"acceptance_decision": "accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "accepted", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "The victim at once becomes insensible, and remains so for some little time, and, when consciousness is once more recovered, suffers great pain. In the case of an old woman death is sure to follow, but in that of a man or younger woman, recovery is possible with the aid of a clever medicine man, who, after much trouble and by dint of long-continued rubbing and sucking, may succeed in extracting the broken bits of Churinga from the patient's body.", "external_id": "sprint-ista-central-australi:ntca15:medicine-man:006", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "explicit_supernatural_or_anomalous_person_form_agent", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "B", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "83d3d9bb5e5ab5eeebf583124448b0102d61215c31e735750dccbd6d1c155038", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "", "rights_access_status": "public_access_text_available", "secondary_role": "source_grounded_section_record", "source_label": "Medicine man", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Medicine man in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}
{"acceptance_decision": "accepted", "access_date": "2026-06-23", "australian_relation": "Central Australian public-domain ethnographic text.", "candidate_status": "accepted", "canonical_url": "https://sacred-texts.com/aus/ntca/ntca15.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "The special breach of custom, with the punishment of which p. 489 the Illapurinja is associated, is the omission of a Mia to cut herself as a mark of sorrow on the death of an Umba, that is, a daughter blood or tribal. Such an omission is a grave offence against a dead Umba, and the dread of punishment at the hands of an Illapurinja must act as a strong inducement to secure the proper carrying out of the ceremony. If one Mia omits to cut herself, then some other one will go in search of her, and, failing the chance of killing her, will strike one of the offending woman's brothers. There is now living at Alice Springs a man who was.", "external_id": "sprint-ista-central-australi:ntca15:medicine-man:007", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "explicit_supernatural_or_anomalous_person_form_agent", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Central Australia, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1899", "publication_or_organisation": "Native Tribes of Central Australia; Baldwin Spencer and F. J. Gillen", "publicness_status": "public_domain_public_web", "quality_class": "B", "raw_metadata_json": {"chapter": "Magic", "evidence_sha256": "dea74dce286de33d4a2c1f9195f4e1dbb939ac0ebbc1e1e3a0807c3f6462e3aa", "route_id": "sprint_ista_central_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntca15", "source_family": "structured_public_domain_books"}, "rejection_reason": "", "rights_access_status": "public_access_text_available", "secondary_role": "source_grounded_section_record", "source_label": "Medicine man", "source_name": "Internet Sacred Text Archive", "source_tier": "A", "source_type": "public_domain_transcribed_book", "title": "Medicine man in Magic", "url": "https://sacred-texts.com/aus/ntca/ntca15.htm"}

{"acceptance_decision": "accepted", "access_date": "2026-06-22", "australian_relation": "Northern Territory public-domain ethnographic text.", "candidate_status": "accepted", "canonical_url": "https://sacred-texts.com/aus/ntna/ntna13.htm", "coordinate_evidence_note": "", "cultural_sensitivity": "moderate", "duplicate_check_status": "source_url_external_id_and_excerpt_hash_checked", "ethics_review_status": "public_context_reviewed", "evidence_summary": "At length Morpun, the great medicine man, arrived. For a while he stood silently, some distance off, watching Mukalakki. First he ordered the women to go away, along way off. Mukalakki sat up. Once more the snake came out of his forehead and looked into his eyes but, at that moment, Morpun, who had come close up, made a sudden snatch at it and caught its head. No one but himself and Mukalakki could see it. He held it very firmly and carefully unwound it from Mukalakki's body. When he had done this successfully, he rolled the snake up in his hands and put it in his dilly bag, called Nunguluwara, and, after staying in camp for one.", "external_id": "sprint-ista-northern-austral:ntna13:medicine-man:007", "geocode_source": "", "geocode_verification_status": "", "humanoid_basis": "explicit_supernatural_or_anomalous_person_form_agent", "latitude": "", "location_precision": "region", "location_role": "cultural_association_region", "location_text": "Northern Territory, NT", "longitude": "", "narrative_type": "descriptive_belief_record", "publication_date_text": "1914", "publication_or_organisation": "Native Tribes of the Northern Territory of Australia; Baldwin Spencer", "publicness_status": "public_domain_public_web", "quality_class": "B", "raw_metadata_json": {"chapter": "Magic and Medicine", "evidence_sha256": "7fe3e6c7d6585dd5a892e42b9b032c68a4935822ef80cffbdc172e95e92ae9cd", "route_id": "sprint_ista_northern_australia_exact_texts", "scope_classifier": "term_and_person_form_gate_v1", "section_id": "ntna13", "source_family